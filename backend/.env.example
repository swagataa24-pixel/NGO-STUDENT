PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
CLIENT_LOGIN_ROUTE=/login
API_ROUTE_AUTH=/api/auth
API_ROUTE_USERS=/api/users
API_ROUTE_CLASSES=/api/classes
API_ROUTE_STUDENTS=/api/students
API_ROUTE_ATTENDANCE=/api/attendance
API_ROUTE_PROGRESS=/api/progress
API_ROUTE_VOLUNTEERS=/api/volunteers
API_ROUTE_PHOTOS=/api/photos
API_ROUTE_REPORTS=/api/reports
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@HOST/upay_ngo?retryWrites=true&w=majority&appName=Cluster0
DNS_SERVERS=8.8.8.8,1.1.1.1

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

JWT_SECRET=any-long-random-string
SESSION_SECRET=any-long-random-string
FIELD_ENCRYPTION_KEY=any-long-random-string
HMAC_SECRET=any-long-random-string
JWT_EXPIRES_IN=1h
ADMIN_EMAILS=

# NOTE: All secret variables (JWT_SECRET, SESSION_SECRET, FIELD_ENCRYPTION_KEY, HMAC_SECRET)
# accept any non-empty string. They will automatically be hashed with SHA-512 and 64
# hex characters extracted from the start, so no need to worry about exact length/format!

