{
  "name": "upay-ngo-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "frontend": "npm run dev --workspace frontend",
    "backend": "npm run dev --workspace backend",
    "start": "npm run start --workspace backend",
    "dev": "concurrently -n backend,frontend \"npm run backend\" \"npm run frontend\"",
    "build": "npm run build --workspace frontend",
    "build:frontend": "npm run build --workspace frontend",
    "start:backend": "npm run start --workspace backend",
    "preview:frontend": "npm run preview --workspace frontend",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}
